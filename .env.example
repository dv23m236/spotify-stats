# Vorlage für die .env-Datei.
# Kopieren nach ".env" und mit echten Werten füllen:
#   cp .env.example .env
#
# Diese Datei (.env.example) darf committet werden, da sie KEINE echten Werte enthält.

# Spotify Developer Dashboard -> deine App -> Settings
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Zufälliger, langer String für Express-Sessions, z.B. generieren mit:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional: Azure Cosmos DB
COSMOS_ENDPOINT=
COSMOS_KEY=

# Lokaler Port
PORT=8000